# Environment
NODE_ENV=development
PORT=3000
WS_PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/raveclone

# Redis
REDIS_URL=redis://localhost:6379

# JWT (REQUIRED in production — server will not start without it)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-64-char-random-string
JWT_EXPIRES_IN=7d

# Social Auth — OAuth Client IDs
# Google: comma-separated list of OAuth client IDs (web + iOS + Android)
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_IDS=123456789-xxxxxxxx.apps.googleusercontent.com

# Apple: comma-separated list of Service IDs (not App IDs)
# Get from: Apple Developer → Certificates, Identifiers & Profiles → Services IDs
APPLE_CLIENT_IDS=com.yourcompany.raveclone.web

# VK: your VK application ID
# Get from: https://vk.com/editapp?act=create
VK_CLIENT_ID=1234567

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# YouTube Extractor
YTDLP_PATH=/usr/local/bin/yt-dlp

# CORS
CORS_ORIGIN=https://raveclone.app,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
